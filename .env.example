# HOMELAB//CTRL Environment Variables
# Copy this to .env and fill in your values

# ── Portainer (Docker/Podman) ────────────────────────────────────────────────
PORTAINER_URL=
PORTAINER_API_KEY= # Your Portainer API key from Settings → API & Webhooks

# Optional: restrict to specific endpoint IDs (leave empty for auto-discovery)
# PORTAINER_ENVS=

# ── AdGuard Home ────────────────────────────────────────────────────────────
ADGUARD_URL=
ADGUARD_USER=
ADGUARD_PASS= # Your AdGuard Home admin password (or API token if using token-based auth)

# ── Wake-on-LAN (WoL) Configuration ─────────────────────────────────────────
WOL_TARGET_MAC= # MAC address of your Ollama desktop PC's network interface
WOL_BROADCAST_IP=255.255.255.255   # Broadcast IP (usually same as above or subnet broadcast)
WOL_PORT=9000                      # UDP port for WOL packets (default is 7, but some use 9000)

# ── Shelly Plugs (Energy Tracking) ──────────────────────────────────────────
SHELLY_PLUG_URL=
SHELLY_PLUG_2_URL=

# ── Storage Mounts ───────────────────────────────────────────────────────────
NFS_MOUNTS=/mnt/nas,/mnt/data  # Comma-separated list of NFS mount points to monitor
